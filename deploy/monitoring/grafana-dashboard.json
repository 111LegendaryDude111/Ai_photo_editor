{
  "title": "Identity Photo Editor - Production",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "sum(rate(photo_editor_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Rejection Rate",
      "targets": [
        {
          "expr": "sum(rate(photo_editor_rejections_total[5m])) / clamp_min(sum(rate(photo_editor_requests_total[5m])), 1e-9)",
          "legendFormat": "reject_ratio"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latency P95 / P99",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(photo_editor_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(photo_editor_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Identity Similarity (P50/P95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(photo_editor_identity_similarity_bucket[10m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(photo_editor_identity_similarity_bucket[10m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "NSFW Score (P95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(photo_editor_nsfw_score_bucket[10m])) by (le))",
          "legendFormat": "nsfw_p95"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser"
}
