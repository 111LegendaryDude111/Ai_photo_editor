# Core service
PHOTO_EDITOR_DEBUG=false
PHOTO_EDITOR_ENABLE_REAL_MODELS=false
PHOTO_EDITOR_ENABLE_CPU_OFFLOAD=true
PHOTO_EDITOR_GENERATION_CFG=7.0
PHOTO_EDITOR_GENERATION_STEPS=30
PHOTO_EDITOR_REFINER_STRENGTH=0.3
PHOTO_EDITOR_DEFAULT_LORA_SCALE=0.8
PHOTO_EDITOR_IDENTITY_THRESHOLD=0.85
PHOTO_EDITOR_IDENTITY_SOFT_WARNING_THRESHOLD=0.75
PHOTO_EDITOR_CLIP_THRESHOLD=0.8
PHOTO_EDITOR_ARTIFACT_THRESHOLD=0.3
PHOTO_EDITOR_NSFW_THRESHOLD=0.8
PHOTO_EDITOR_MAX_QUALITY_RETRIES=3
PHOTO_EDITOR_AB_VARIANTS=2
PHOTO_EDITOR_ENABLE_FACE_LOCK_MASK=true
PHOTO_EDITOR_INPUT_MAX_RESOLUTION=2048
PHOTO_EDITOR_INPUT_MAX_FILE_SIZE_MB=8.0
PHOTO_EDITOR_INPUT_MIN_FACES=1
PHOTO_EDITOR_INPUT_MAX_FACES=1
PHOTO_EDITOR_AUTH_ENABLED=false
PHOTO_EDITOR_API_KEYS=
PHOTO_EDITOR_JWT_SECRET=change-me-jwt-secret
PHOTO_EDITOR_RATE_LIMIT_ENABLED=true
PHOTO_EDITOR_RATE_LIMIT_PER_USER_PER_MINUTE=60
PHOTO_EDITOR_RATE_LIMIT_PER_IP_PER_MINUTE=120

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
PHOTO_EDITOR_MINIO_ACCESS_KEY=minioadmin
PHOTO_EDITOR_MINIO_SECRET_KEY=change-me-minio-password
PHOTO_EDITOR_MINIO_BUCKET=generated-images

# Postgres
POSTGRES_PASSWORD=change-me-postgres-password

# Redis/Celery
PHOTO_EDITOR_CELERY_BROKER_URL=redis://redis:6379/0
PHOTO_EDITOR_CELERY_RESULT_BACKEND=redis://redis:6379/1
PHOTO_EDITOR_CELERY_BATCH_SIZE=4
