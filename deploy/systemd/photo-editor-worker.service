[Unit]
Description=Identity Photo Editor Worker (Celery)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=photoeditor
Group=photoeditor
WorkingDirectory=/opt/ai-photo-editor
EnvironmentFile=/opt/ai-photo-editor/.env
ExecStart=/usr/bin/env uv run celery -A app.workers.celery_app:celery_app worker -l info --concurrency=2
Restart=always
RestartSec=3
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
